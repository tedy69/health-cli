  },
  "keywords": [
    "health",
    "health-check",
    "diagnostics",
    "monorepo",
    "cli",
    "dependency-audit",
    "dead-code",
    "unused-exports",
    "circular-deps",
    "circular-dependencies",
    "code-quality",
    "static-analysis",
    "repo-hygiene",
    "bundle-size",
    "typescript",
    "eslint",
    "sarif",
    "ci",
    "devtools",
    "linter",
    "project-health"
  ],
  "author": "tedy69 (https://github.com/tedy69)",
  "license": "MIT",
